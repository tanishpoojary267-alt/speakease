{
    "description": "Speakease AI — Emotion Dataset v1",
    "info": "Maps face-api.js raw emotion names to interview-relevant states. face-api detects 7 base emotions. We remap them to what they MEAN in an interview context.",
    "howToExtend": "Add/edit entries below. Keys must match face-api.js emotion names: neutral, happy, sad, angry, fearful, surprised, disgusted",
    "emotions": {
        "neutral": {
            "interviewLabel": "Stable",
            "interviewState": "stable",
            "confidenceScore": 70,
            "color": "#38bdf8",
            "emoji": "🎯",
            "feedback": "You look calm and focused. Add brief smiles to appear warm.",
            "audio": {
                "freq": 440,
                "type": "sine",
                "duration": 0.2,
                "gain": 0.04
            },
            "severity": "normal"
        },
        "happy": {
            "interviewLabel": "Confident",
            "interviewState": "confident",
            "confidenceScore": 85,
            "color": "#22c55e",
            "emoji": "✅",
            "feedback": "You look confident and positive! Keep a natural, composed smile.",
            "audio": {
                "freq": 880,
                "type": "sine",
                "duration": 0.3,
                "gain": 0.06
            },
            "severity": "positive"
        },
        "sad": {
            "interviewLabel": "Low Confidence",
            "interviewState": "low_confidence",
            "confidenceScore": 25,
            "color": "#f59e0b",
            "emoji": "😔",
            "feedback": "You appear low-energy. Sit up straight, project your voice, make eye contact.",
            "audio": {
                "freq": 300,
                "type": "sine",
                "duration": 0.4,
                "gain": 0.05,
                "sweep": 220
            },
            "severity": "warning",
            "note": "In interviews, sad expression = low confidence/energy. Not actual sadness."
        },
        "angry": {
            "interviewLabel": "Stressed",
            "interviewState": "stressed",
            "confidenceScore": 20,
            "color": "#dc2626",
            "emoji": "😤",
            "feedback": "You look tense. Relax your jaw and forehead. Soften your expression.",
            "audio": {
                "freq": 180,
                "type": "square",
                "duration": 0.25,
                "gain": 0.06
            },
            "severity": "critical"
        },
        "fearful": {
            "interviewLabel": "Nervous",
            "interviewState": "nervous",
            "confidenceScore": 30,
            "color": "#f97316",
            "emoji": "😟",
            "feedback": "You appear nervous. Take a slow breath. Speak at a steady, deliberate pace.",
            "audio": {
                "freq": 220,
                "type": "triangle",
                "duration": 0.5,
                "gain": 0.07
            },
            "severity": "warning",
            "doublePulse": true
        },
        "surprised": {
            "interviewLabel": "Uncertain",
            "interviewState": "uncertain",
            "confidenceScore": 50,
            "color": "#a855f7",
            "emoji": "😲",
            "feedback": "You look surprised. Buy time: say 'That is a great question, let me think...'",
            "audio": {
                "freq": 520,
                "type": "sine",
                "duration": 0.3,
                "gain": 0.05,
                "sweep": 660
            },
            "severity": "warning"
        },
        "disgusted": {
            "interviewLabel": "Uncomfortable",
            "interviewState": "uncomfortable",
            "confidenceScore": 35,
            "color": "#64748b",
            "emoji": "😒",
            "feedback": "You look uncomfortable. Keep a neutral, professional expression regardless of the question.",
            "audio": {
                "freq": 200,
                "type": "triangle",
                "duration": 0.35,
                "gain": 0.05
            },
            "severity": "warning"
        }
    }
}